{
  "name": "routescribe",
  "version": "1.0.0",
  "description": "Runtime API documentation and intelligence for Express applications.",
  "author": "Yuvaan Singh",
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "routescribe": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/playground.ts",
    "playground": "tsx src/playground.ts",
    "playground:express": "tsx src/playground-express.ts",
    "playground:file": "tsx src/playground-file-storage.ts",
    "playground:json": "tsx src/playground-json.ts",
    "playground:openapi": "tsx src/playground-openapi.ts",
    "playground:builders": "tsx src/playground-builders.ts",
    "playground:schema": "tsx src/playground-schema.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli/index.ts"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "express": "^5.2.1",
    "yaml": "^2.9.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuvaan1182/routescribe.git"
  },
  "homepage": "https://github.com/Yuvaan1182/routescribe",
  "bugs": {
    "url": "https://github.com/Yuvaan1182/routescribe/issues"
  },
  "keywords": [
    "openapi",
    "swagger",
    "express",
    "api",
    "documentation",
    "middleware",
    "typescript",
    "rest"
  ],
  "engines": {
    "node": ">=18"
  }
}
